# =============================================================================
# Cyber Threat Hunting Agent — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime / generated data  (never commit these)
# -----------------------------------------------------------------------------
data/logs.sqlite
data/*.sqlite
data/*.sqlite-shm
data/*.sqlite-wal
data/*.db
data/*.db-shm
data/*.db-wal

# -----------------------------------------------------------------------------
# Python artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
build/
dist/
wheels/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.env/

# -----------------------------------------------------------------------------
# Environment / secrets files  (API keys, credentials — NEVER commit)
# -----------------------------------------------------------------------------
.env
.env.*
*.env
!.env.example

# -----------------------------------------------------------------------------
# uv / pip / packaging caches
# -----------------------------------------------------------------------------
.uv/
.cache/
*.whl
site-packages/

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------

# VS Code
.vscode/
*.code-workspace

# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# -----------------------------------------------------------------------------
# OS generated files
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
eaDir/

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# Logs and temp files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig

# -----------------------------------------------------------------------------
# Test / coverage artifacts
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/

# -----------------------------------------------------------------------------
# Type-checker / linter caches
# -----------------------------------------------------------------------------
.mypy_cache/
.pyright/
.ruff_cache/

# -----------------------------------------------------------------------------
# Jupyter Notebooks (checkpoints only — keep .ipynb files if any)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

.AGENT_DOCUMENTATION.md
.CHANGELOG.md